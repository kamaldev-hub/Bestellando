# Application Configuration
APP_NAME="Bestellando"
APP_ENV="development" # development, production, testing
APP_DEBUG="true" # true or false
APP_URL="http://localhost"
APP_PORT="8080" # Port the web server will be accessible on the host

# Database Configuration (MySQL)
DB_CONNECTION="mysql"
DB_HOST="db" # This should match the service name in docker-compose.yml for the db container
DB_PORT="3306" # Port MySQL runs on *inside* the db container (default 3306)
DB_DATABASE="bestellando_db"
DB_USER="bestellando_user"
DB_PASSWORD="bestellando_password"
DB_ROOT_PASSWORD="root_secret_password" # MySQL root password for the db container

# For testing environment (can be overridden in phpunit.xml or specific test setup)
# TEST_DB_HOST="localhost" # or your docker host IP if running tests outside containers against containerized DB
# TEST_DB_DATABASE="bestellando_test_db"
# TEST_DB_USER="test_user"
# TEST_DB_PASSWORD="test_password"

# CSRF Token Name (Example)
CSRF_TOKEN_NAME="csrf_token"

# Session Configuration (Example)
SESSION_NAME="bestellando_session"
SESSION_LIFETIME="120" # Minutes

# Add any other application-specific environment variables here
# E.g., API keys, mail settings, etc.
